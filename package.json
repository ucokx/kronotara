{
  "name": "kronotara",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "wrangler pages dev ./build/client",
    "deploy": "npm run build && wrangler pages deploy ./build/client",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint --max-warnings=0 .",
    "format": "prettier --write .",
    "db:migrate:local": "wrangler d1 migrations apply kronotara-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply kronotara-db --remote",
    "db:studio": "wrangler d1 studio kronotara-db"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@deck.gl/aggregation-layers": "^9.3.7",
    "@deck.gl/core": "^9.1.10",
    "@deck.gl/layers": "^9.1.10",
    "@deck.gl/react": "^9.1.10",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-router/cloudflare": "^7.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.27",
    "lucide-react": "^0.513.0",
    "maplibre-gl": "^5.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.18.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@react-router/dev": "^7.18.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint": "^9.30.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
